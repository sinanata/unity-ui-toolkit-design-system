# Unity-generated artefacts (anchored so Tools/Build/ isn't swept up)
/Library/
/Temp/
/Obj/
/Logs/
/UserSettings/
/MemoryCaptures/
/Builds/

# Local WebGL build output (showcase orchestrator writes here)
/build/
Tools/Build/output/
Tools/Build/config.local.json

# Local gh-pages deploy worktree (created and removed by Deploy-GhPages.ps1)
.gh-pages-tmp/

# Visual Studio / Rider — generated by Unity, regenerated on import
.vs/
.idea/
*.csproj
*.sln
*.suo
*.user
*.unityproj
*.booproj

# OS metadata
.DS_Store
Thumbs.db
desktop.ini

# Editor junk
.vscode/
*.swp
*~

# Unity .meta files for the design system are intentionally NOT ignored —
# they carry import settings (svgType, asmdef refs, etc.) that consumers
# should reuse rather than regenerate.
