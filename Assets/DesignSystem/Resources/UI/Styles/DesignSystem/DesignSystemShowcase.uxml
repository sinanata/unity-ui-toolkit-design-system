            <ui:VisualElement class="ds-section" style="width: 280px;">
                <ui:Label text="TOGGLES &amp; CHECKS" class="ds-section__title"/>
                <ui:VisualElement class="ds-row" style="justify-content: space-between;">
                    <ui:Label text="Toggle On" class="ds-body-1"/>
                    <ui:Toggle value="true" class="ds-toggle">
                        <ui:VisualElement class="ds-toggle__knob"/>
                    </ui:Toggle>
                </ui:VisualElement>
                <ui:VisualElement class="ds-row" style="justify-content: space-between;">
                    <ui:Label text="Toggle Off" class="ds-body-1"/>
                    <ui:Toggle value="false" class="ds-toggle">
                        <ui:VisualElement class="ds-toggle__knob"/>
                    </ui:Toggle>
                </ui:VisualElement>
                <ui:VisualElement class="ds-row" style="justify-content: space-between; margin-top: 12px;">
                    <ui:Label text="Checkbox On" class="ds-body-1"/>
                    <ui:Toggle value="true" class="ds-check"/>
                </ui:VisualElement>
                <ui:VisualElement class="ds-row" style="justify-content: space-between;">
                    <ui:Label text="Checkbox Off" class="ds-body-1"/>
                    <ui:Toggle value="false" class="ds-check"/>
                </ui:VisualElement>
                <ui:RadioButtonGroup style="margin-top: 12px;">
                    <ui:VisualElement class="ds-row" style="justify-content: space-between;">
                        <ui:Label text="Radio Selected" class="ds-body-1"/>
                        <ui:RadioButton value="true" class="ds-radio"/>
                    </ui:VisualElement>
                    <ui:VisualElement class="ds-row" style="justify-content: space-between;">
                        <ui:Label text="Radio Unselected" class="ds-body-1"/>
                        <ui:RadioButton value="false" class="ds-radio"/>
                    </ui:VisualElement>
                </ui:RadioButtonGroup>
            </ui:VisualElement>
            <ui:VisualElement class="ds-section" style="width: 280px;">
                <ui:Label text="SLIDERS" class="ds-section__title"/>
                <ui:VisualElement class="ds-progress-row" style="margin-bottom: 24px;">
                    <ui:VisualElement class="ds-progress-row__head">
                        <ui:Label text="Progress" class="ds-body-2"/>
                        <ui:Label text="68%" class="ds-body-2 ds-text-primary"/>
                    </ui:VisualElement>
                    <ui:ProgressBar value="68" low-value="0" high-value="100" class="ds-progress"/>
                </ui:VisualElement>
                <ui:Label text="Slider" class="ds-body-2"/>
                <ui:Slider low-value="0" high-value="100" value="50" class="ds-slider ds-slider--filled" style="margin-bottom: 12px;"/>
                <ui:Label text="Range" class="ds-body-2"/>
                <ui:MinMaxSlider low-limit="0" high-limit="100" value="0,0" class="ds-range"/>
            </ui:VisualElement>
            <ui:VisualElement class="ds-section" style="width: 700px;">
                <ui:Label text="MODALS / PANELS" class="ds-section__title"/>
                <ui:VisualElement style="flex-direction: row; flex-wrap: wrap;">
                    <ui:VisualElement class="ds-modal" style="margin: 6px;">
                        <ui:VisualElement class="ds-modal__header" style="justify-content: flex-end;">
                            <ui:Button class="ds-modal__close">
                                <ui:VisualElement class="ds-icon ds-icon--sm ds-icon--close"/>
                            </ui:Button>
                        </ui:VisualElement>
                        <ui:VisualElement class="ds-modal__body" style="align-items: center;">
                            <ui:Label text="Equip Frog?" class="ds-h3" style="margin-bottom: 8px;"/>
                            <ui:Label text="This will unequip your current animal." class="ds-body-2" style="-unity-text-align: middle-center; white-space: normal;"/>
                        </ui:VisualElement>
                        <ui:VisualElement class="ds-modal__actions">
                            <ui:Button text="Cancel" class="ds-btn ds-btn--ghost"/>
                            <ui:Button text="Equip" class="ds-btn ds-btn--primary"/>
                        </ui:VisualElement>
                    </ui:VisualElement>
                    <ui:VisualElement class="ds-modal" style="margin: 6px;">
                        <ui:VisualElement class="ds-modal__header">
                            <ui:Label text="Sort by" class="ds-modal__title"/>
                            <ui:Button class="ds-modal__close">
                                <ui:VisualElement class="ds-icon ds-icon--sm ds-icon--close"/>
                            </ui:Button>
                        </ui:VisualElement>
                        <ui:RadioButtonGroup>
                            <ui:VisualElement class="ds-modal__list-row">
                                <ui:Label text="Newest" class="ds-modal__list-label"/>
                                <ui:RadioButton value="true" class="ds-radio"/>
                            </ui:VisualElement>
                            <ui:VisualElement class="ds-modal__list-row">
                                <ui:Label text="Oldest" class="ds-modal__list-label"/>
                                <ui:RadioButton value="false" class="ds-radio"/>
                            </ui:VisualElement>
                            <ui:VisualElement class="ds-modal__list-row">
                                <ui:Label text="Name (A-Z)" class="ds-modal__list-label"/>
                                <ui:RadioButton value="false" class="ds-radio"/>
                            </ui:VisualElement>
                            <ui:VisualElement class="ds-modal__list-row">
                                <ui:Label text="Name (Z-A)" class="ds-modal__list-label"/>
                                <ui:RadioButton value="false" class="ds-radio"/>
                            </ui:VisualElement>
                        </ui:RadioButtonGroup>
                    </ui:VisualElement>
                    <ui:VisualElement class="ds-modal" style="margin: 6px;">
                        <ui:VisualElement class="ds-modal__header">
                            <ui:Label text="Filter by Habitat" class="ds-modal__title"/>
                            <ui:Button class="ds-modal__close">
                                <ui:VisualElement class="ds-icon ds-icon--sm ds-icon--close"/>
                            </ui:Button>
                        </ui:VisualElement>
                        <ui:VisualElement class="ds-modal__list-row">
                            <ui:Label text="All Habitats" class="ds-modal__list-label"/>
                            <ui:Toggle value="true" class="ds-check"/>
                        </ui:VisualElement>
                        <ui:VisualElement class="ds-modal__list-row">
                            <ui:Label text="Pond" class="ds-modal__list-label"/>
                            <ui:Toggle value="false" class="ds-check"/>
                        </ui:VisualElement>
                        <ui:VisualElement class="ds-modal__list-row">
                            <ui:Label text="Forest" class="ds-modal__list-label"/>
                            <ui:Toggle value="false" class="ds-check"/>
                        </ui:VisualElement>
                        <ui:VisualElement class="ds-modal__list-row">
                            <ui:Label text="Desert" class="ds-modal__list-label"/>
                            <ui:Toggle value="false" class="ds-check"/>
                        </ui:VisualElement>
                        <ui:VisualElement class="ds-modal__list-row">
                            <ui:Label text="Mountain" class="ds-modal__list-label"/>
                            <ui:Toggle value="false" class="ds-check"/>
                        </ui:VisualElement>
                    </ui:VisualElement>
                    <ui:VisualElement class="ds-modal" style="margin: 6px;">
                        <ui:VisualElement class="ds-modal__header">
                            <ui:Label text="Animal Limit" class="ds-modal__title"/>
                            <ui:Button class="ds-modal__close">
                                <ui:VisualElement class="ds-icon ds-icon--sm ds-icon--close"/>
                            </ui:Button>
                        </ui:VisualElement>
                        <ui:VisualElement class="ds-modal__illustration">
                            <ui:Label text="🐸" style="font-size: 48px;"/>
                        </ui:VisualElement>
                        <ui:Label text="You have reached the maximum number of animals." class="ds-body-2" style="-unity-text-align: middle-center; white-space: normal; margin-bottom: 12px;"/>
                        <ui:Button text="Upgrade" class="ds-btn ds-btn--primary ds-btn--block"/>
                    </ui:VisualElement>
                </ui:VisualElement>
            </ui:VisualElement>
            <ui:VisualElement class="ds-section" style="width: 320px;">
                <ui:Label text="TOASTS" class="ds-section__title"/>
                <ui:VisualElement class="ds-toast ds-toast--success">
                    <ui:VisualElement class="ds-icon ds-icon--sm ds-icon--check ds-toast__icon"/>
                    <ui:Label text="Frog equipped successfully!" class="ds-toast__message"/>
                    <ui:Button class="ds-toast__close">
                        <ui:VisualElement class="ds-icon ds-icon--sm ds-icon--close"/>
                    </ui:Button>
                </ui:VisualElement>
                <ui:VisualElement class="ds-toast ds-toast--info">
                    <ui:VisualElement class="ds-icon ds-icon--sm ds-icon--info ds-toast__icon"/>
                    <ui:Label text="Snapping Turtle added to your collection!" class="ds-toast__message"/>
                    <ui:Button class="ds-toast__close">
                        <ui:VisualElement class="ds-icon ds-icon--sm ds-icon--close"/>
                    </ui:Button>
                </ui:VisualElement>
                <ui:VisualElement class="ds-toast ds-toast--warning">
                    <ui:VisualElement class="ds-icon ds-icon--sm ds-icon--warning ds-toast__icon"/>
                    <ui:Label text="Cheetah is already equipped." class="ds-toast__message"/>
                    <ui:Button class="ds-toast__close">
                        <ui:VisualElement class="ds-icon ds-icon--sm ds-icon--close"/>
                    </ui:Button>
                </ui:VisualElement>
                <ui:VisualElement class="ds-toast ds-toast--danger">
                    <ui:VisualElement class="ds-icon ds-icon--sm ds-icon--error ds-toast__icon"/>
                    <ui:Label text="Failed to equip animal." class="ds-toast__message"/>
                    <ui:Button class="ds-toast__close">
                        <ui:VisualElement class="ds-icon ds-icon--sm ds-icon--close"/>
                    </ui:Button>
                </ui:VisualElement>
            </ui:VisualElement>
            <ui:VisualElement class="ds-section" style="width: 360px;">
                <ui:Label text="EMPTY STATES" class="ds-section__title"/>
                <ui:VisualElement style="flex-direction: row;">
                    <ui:VisualElement class="ds-empty" style="flex-grow: 1;">
                        <ui:VisualElement class="ds-empty__icon-bg">
                            <ui:VisualElement class="ds-icon ds-icon--lg ds-icon--paw"/>
                        </ui:VisualElement>
                        <ui:Label text="No animals yet" class="ds-empty__title"/>
                        <ui:Label text="Start your collection by discovering animals!" class="ds-empty__message"/>
                        <ui:Button text="Explore" class="ds-btn ds-btn--primary"/>
                    </ui:VisualElement>
                    <ui:VisualElement class="ds-empty" style="flex-grow: 1;">
                        <ui:VisualElement class="ds-empty__icon-bg">
                            <ui:VisualElement class="ds-icon ds-icon--lg ds-icon--search"/>
                        </ui:VisualElement>
                        <ui:Label text="No results found" class="ds-empty__title"/>
                        <ui:Label text="Try adjusting your filters or search term." class="ds-empty__message"/>
                        <ui:Button text="Clear Filters" class="ds-btn ds-btn--ghost"/>
                    </ui:VisualElement>
                </ui:VisualElement>
            </ui:VisualElement>
            <ui:VisualElement class="ds-section" style="width: 320px;">
                <ui:Label text="BOTTOM SHEET / DRAWER (MOBILE)" class="ds-section__title"/>
                <ui:VisualElement class="ds-sheet">
                    <ui:VisualElement class="ds-sheet__handle"/>
                    <ui:VisualElement class="ds-sheet__row">
                        <ui:VisualElement class="ds-icon ds-icon--sm ds-icon--more-horizontal ds-sheet__row-icon"/>
                        <ui:Label text="More Options" class="ds-sheet__row-label"/>
                    </ui:VisualElement>
                    <ui:VisualElement class="ds-sheet__row">
                        <ui:VisualElement class="ds-icon ds-icon--sm ds-icon--list ds-sheet__row-icon"/>
                        <ui:Label text="View Details" class="ds-sheet__row-label"/>
                    </ui:VisualElement>
                    <ui:VisualElement class="ds-sheet__row">
                        <ui:VisualElement class="ds-icon ds-icon--sm ds-icon--shirt ds-sheet__row-icon"/>
                        <ui:Label text="Change Skin" class="ds-sheet__row-label"/>
                    </ui:VisualElement>
                    <ui:VisualElement class="ds-sheet__row">
                        <ui:VisualElement class="ds-icon ds-icon--sm ds-icon--heart ds-sheet__row-icon"/>
                        <ui:Label text="Favourite" class="ds-sheet__row-label"/>
                        <ui:Toggle value="true" class="ds-toggle">
                            <ui:VisualElement class="ds-toggle__knob"/>
                        </ui:Toggle>
                    </ui:VisualElement>
                    <ui:VisualElement class="ds-sheet__row ds-sheet__row--danger">
                        <ui:VisualElement class="ds-icon ds-icon--sm ds-icon--trash ds-icon--danger ds-sheet__row-icon"/>
                        <ui:Label text="Release" class="ds-sheet__row-label"/>
                    </ui:VisualElement>
                </ui:VisualElement>
            </ui:VisualElement>
            <ui:VisualElement class="ds-section" style="width: 320px;">
                <ui:Label text="CONFIRM DIALOG" class="ds-section__title"/>
                <ui:VisualElement class="ds-dialog" style="align-self: center;">
                    <ui:VisualElement style="flex-direction: row; justify-content: flex-end; width: 100%;">
                        <ui:Button class="ds-modal__close">
                            <ui:VisualElement class="ds-icon ds-icon--sm ds-icon--close"/>
                        </ui:Button>
                    </ui:VisualElement>
                    <ui:Label text="Release Frog?" class="ds-dialog__title"/>
                    <ui:Label text="Are you sure you want to release this animal? This action cannot be undone." class="ds-dialog__message"/>
                    <ui:VisualElement class="ds-dialog__actions">
                        <ui:Button text="Cancel" class="ds-btn ds-btn--ghost"/>
                        <ui:Button text="Release" class="ds-btn ds-btn--danger"/>
                    </ui:VisualElement>
                </ui:VisualElement>
            </ui:VisualElement>
            <ui:VisualElement class="ds-section" style="width: 200px;">
                <ui:Label text="QUANTITY SELECTOR" class="ds-section__title"/>
                <ui:VisualElement class="ds-stepper">
                    <ui:Button text="−" class="ds-stepper__btn"/>
                    <ui:Label text="1" class="ds-stepper__value"/>
                    <ui:Button text="+" class="ds-stepper__btn"/>
                </ui:VisualElement>
            </ui:VisualElement>
            <ui:VisualElement class="ds-section" style="width: 280px;">
                <ui:Label text="PAGINATION" class="ds-section__title"/>
                <ui:VisualElement class="ds-pagination">
                    <ui:Button class="ds-pagination__btn">
                        <ui:VisualElement class="ds-icon ds-icon--xs ds-icon--chevron-left"/>
                    </ui:Button>
                    <ui:Button text="1" class="ds-pagination__btn is-active"/>
                    <ui:Button text="2" class="ds-pagination__btn"/>
                    <ui:Button text="3" class="ds-pagination__btn"/>
                    <ui:Label text="..." class="ds-pagination__ellipsis"/>
                    <ui:Button text="8" class="ds-pagination__btn"/>
                    <ui:Button class="ds-pagination__btn">
                        <ui:VisualElement class="ds-icon ds-icon--xs ds-icon--chevron-right"/>
                    </ui:Button>
                </ui:VisualElement>
            </ui:VisualElement>
            <ui:VisualElement class="ds-section" style="width: 660px;">
                <ui:Label text="LOADING STATES" class="ds-section__title"/>
                <ui:VisualElement style="flex-direction: column;">
                    <ui:VisualElement style="flex-direction: column; margin-bottom: 16px;">
                        <ui:Label text="Spinner" class="ds-body-2" style="margin-bottom: 8px;"/>
                        <ui:VisualElement class="ds-spinner ds-spinner--lg is-spinning"/>
                    </ui:VisualElement>
                    <ui:VisualElement style="flex-direction: column; margin-bottom: 16px;">
                        <ui:Label text="Skeleton Cards" class="ds-body-2" style="margin-bottom: 8px;"/>
                        <ui:VisualElement style="flex-direction: row;">
                            <ui:VisualElement class="ds-skeleton ds-skeleton--card" style="margin-right: 8px;"/>
                            <ui:VisualElement class="ds-skeleton ds-skeleton--card" style="margin-right: 8px;"/>
                            <ui:VisualElement class="ds-skeleton ds-skeleton--card"/>
                        </ui:VisualElement>
                    </ui:VisualElement>
                    <ui:VisualElement style="flex-direction: column;">
                        <ui:VisualElement class="ds-progress-row__head">
                            <ui:Label text="Loading..." class="ds-body-2"/>
                            <ui:Label text="42%" class="ds-body-2 ds-text-primary"/>
                        </ui:VisualElement>
                        <ui:ProgressBar value="42" low-value="0" high-value="100" class="ds-progress"/>
                    </ui:VisualElement>
                </ui:VisualElement>
            </ui:VisualElement>
            <ui:VisualElement class="ds-section" style="width: 200px;">
                <ui:Label text="NOTIFICATION BADGE" class="ds-section__title"/>
                <ui:VisualElement class="ds-notif-wrap">
                    <ui:VisualElement class="ds-icon ds-icon--lg ds-icon--bell ds-icon--primary ds-notif-icon"/>
                    <ui:VisualElement class="ds-notif-dot">
                        <ui:Label text="3" class="ds-notif-dot__count"/>
                    </ui:VisualElement>
                </ui:VisualElement>
            </ui:VisualElement>
            <ui:VisualElement class="ds-section" style="width: 200px;">
                <ui:Label text="AVATAR" class="ds-section__title"/>
                <ui:VisualElement style="flex-direction: row; align-items: center;">
                    <ui:VisualElement class="ds-avatar ds-avatar--xl" style="margin-right: 8px;"/>
                    <ui:VisualElement style="flex-direction: column;">
                        <ui:VisualElement class="ds-avatar ds-avatar--md" style="margin-bottom: 4px;"/>
                        <ui:VisualElement class="ds-avatar ds-avatar--sm"/>
                    </ui:VisualElement>
                </ui:VisualElement>
            </ui:VisualElement>
        </ui:VisualElement>
    </ui:ScrollView>
</ui:UXML>
