<ui:UXML xmlns:ui="UnityEngine.UIElements" xmlns:uie="UnityEditor.UIElements" xsi="http://www.w3.org/2001/XMLSchema-instance" engine="UnityEngine.UIElements" editor="UnityEditor.UIElements" noNamespaceSchemaLocation="../../UIElementsSchema/UIElements.xsd" editor-extension-mode="False">
    <Style src="DesignSystem.uss"/>
    <ui:ScrollView mode="Vertical" class="ds-root">
        <ui:VisualElement style="flex-direction: row; flex-wrap: wrap; padding: 12px;">
            <ui:VisualElement class="ds-section" style="width: 240px;">
                <ui:Label text="COLORS" class="ds-section__title"/>
                <ui:VisualElement class="ds-swatch-row">
                    <ui:VisualElement class="ds-swatch" style="background-color: rgb(34, 197, 94);"/>
                    <ui:Label text="Primary" class="ds-swatch__name"/>
                    <ui:Label text="#22C55E" class="ds-swatch__hex"/>
                </ui:VisualElement>
                <ui:VisualElement class="ds-swatch-row">
                    <ui:VisualElement class="ds-swatch" style="background-color: rgb(22, 163, 74);"/>
                    <ui:Label text="Primary Hover" class="ds-swatch__name"/>
                    <ui:Label text="#16A34A" class="ds-swatch__hex"/>
                </ui:VisualElement>
                <ui:VisualElement class="ds-swatch-row">
                    <ui:VisualElement class="ds-swatch" style="background-color: rgb(59, 130, 246);"/>
                    <ui:Label text="Secondary" class="ds-swatch__name"/>
                    <ui:Label text="#3B82F6" class="ds-swatch__hex"/>
                </ui:VisualElement>
                <ui:VisualElement class="ds-swatch-row">
                    <ui:VisualElement class="ds-swatch" style="background-color: rgb(168, 85, 247);"/>
                    <ui:Label text="Tertiary" class="ds-swatch__name"/>
                    <ui:Label text="#A855F7" class="ds-swatch__hex"/>
                </ui:VisualElement>
                <ui:VisualElement class="ds-swatch-row">
                    <ui:VisualElement class="ds-swatch" style="background-color: rgb(245, 158, 11);"/>
                    <ui:Label text="Warning" class="ds-swatch__name"/>
                    <ui:Label text="#F59E0B" class="ds-swatch__hex"/>
                </ui:VisualElement>
                <ui:VisualElement class="ds-swatch-row">
                    <ui:VisualElement class="ds-swatch" style="background-color: rgb(239, 68, 68);"/>
                    <ui:Label text="Danger" class="ds-swatch__name"/>
                    <ui:Label text="#EF4444" class="ds-swatch__hex"/>
                </ui:VisualElement>
                <ui:VisualElement class="ds-swatch-row">
                    <ui:VisualElement class="ds-swatch" style="background-color: rgb(242, 244, 247);"/>
                    <ui:Label text="Text Primary" class="ds-swatch__name"/>
                    <ui:Label text="#F2F4F7" class="ds-swatch__hex"/>
                </ui:VisualElement>
                <ui:VisualElement class="ds-swatch-row">
                    <ui:VisualElement class="ds-swatch" style="background-color: rgb(161, 167, 179);"/>
                    <ui:Label text="Text Secondary" class="ds-swatch__name"/>
                    <ui:Label text="#A1A7B3" class="ds-swatch__hex"/>
                </ui:VisualElement>
                <ui:VisualElement class="ds-swatch-row">
                    <ui:VisualElement class="ds-swatch" style="background-color: rgb(103, 112, 133);"/>
                    <ui:Label text="Text Disabled" class="ds-swatch__name"/>
                    <ui:Label text="#677085" class="ds-swatch__hex"/>
                </ui:VisualElement>
                <ui:VisualElement class="ds-swatch-row">
                    <ui:VisualElement class="ds-swatch" style="background-color: rgb(11, 15, 23);"/>
                    <ui:Label text="Background" class="ds-swatch__name"/>
                    <ui:Label text="#0B0F17" class="ds-swatch__hex"/>
                </ui:VisualElement>
                <ui:VisualElement class="ds-swatch-row">
                    <ui:VisualElement class="ds-swatch" style="background-color: rgb(19, 26, 36);"/>
                    <ui:Label text="Surface" class="ds-swatch__name"/>
                    <ui:Label text="#131A24" class="ds-swatch__hex"/>
                </ui:VisualElement>
                <ui:VisualElement class="ds-swatch-row">
                    <ui:VisualElement class="ds-swatch" style="background-color: rgb(26, 35, 48);"/>
                    <ui:Label text="Surface Elevated" class="ds-swatch__name"/>
                    <ui:Label text="#1A2330" class="ds-swatch__hex"/>
                </ui:VisualElement>
                <ui:VisualElement class="ds-swatch-row">
                    <ui:VisualElement class="ds-swatch" style="background-color: rgb(38, 48, 65);"/>
                    <ui:Label text="Border" class="ds-swatch__name"/>
                    <ui:Label text="#263041" class="ds-swatch__hex"/>
                </ui:VisualElement>
            </ui:VisualElement>
            <ui:VisualElement class="ds-section" style="width: 280px;">
                <ui:Label text="TYPOGRAPHY" class="ds-section__title"/>
                <ui:VisualElement style="flex-direction: row; align-items: flex-end; margin-bottom: 12px;">
                    <ui:Label text="Aa" class="ds-h1" style="font-size: 64px; margin-right: 16px;"/>
                    <ui:Label text="Aa" class="ds-h2" style="font-size: 40px; color: rgb(161, 167, 179);"/>
                </ui:VisualElement>
                <ui:Label text="Heading 1" class="ds-h1"/>
                <ui:Label text="Inter Regular / 26 / Bold" class="ds-body-2" style="margin-bottom: 12px;"/>
                <ui:Label text="Heading 2" class="ds-h2"/>
                <ui:Label text="Inter Regular / 20 / Bold" class="ds-body-2" style="margin-bottom: 12px;"/>
                <ui:Label text="Heading 3" class="ds-h3"/>
                <ui:Label text="Inter Regular / 16 / Semibold" class="ds-body-2" style="margin-bottom: 12px;"/>
                <ui:Label text="Body 1" class="ds-body-1"/>
                <ui:Label text="Inter Regular / 14 / Regular" class="ds-body-2" style="margin-bottom: 12px;"/>
                <ui:Label text="Body 2" class="ds-body-2" style="color: rgb(242, 244, 247);"/>
                <ui:Label text="Inter Regular / 12 / Regular" class="ds-body-2" style="margin-bottom: 12px;"/>
                <ui:Label text="Caption" class="ds-caption"/>
                <ui:Label text="Inter Regular / 11 / Medium" class="ds-body-2"/>
            </ui:VisualElement>
            <ui:VisualElement class="ds-section" style="width: 490px;">
                <ui:Label text="BUTTONS" class="ds-section__title"/>
                <ui:VisualElement class="ds-row">
                    <ui:Label text="Primary" class="ds-body-2" style="width: 70px;"/>
                    <ui:Button text="Default" class="ds-btn ds-btn--primary" style="margin-right: 6px;"/>
                    <ui:Button text="Hover" class="ds-btn ds-btn--primary" style="margin-right: 6px; background-color: rgb(22, 163, 74);"/>
                    <ui:Button text="Pressed" class="ds-btn ds-btn--primary ds-btn--pressed" style="margin-right: 6px;"/>
                    <ui:Button text="Disabled" enabled="false" class="ds-btn ds-btn--primary" style="margin-right: 6px;"/>
                </ui:VisualElement>
                <ui:VisualElement class="ds-row">
                    <ui:Label text="Secondary" class="ds-body-2" style="width: 70px;"/>
                    <ui:Button text="Default" class="ds-btn ds-btn--secondary" style="margin-right: 6px;"/>
                    <ui:Button text="Hover" class="ds-btn ds-btn--secondary" style="margin-right: 6px; background-color: rgb(37, 99, 235);"/>
                    <ui:Button text="Pressed" class="ds-btn ds-btn--secondary ds-btn--pressed" style="margin-right: 6px;"/>
                    <ui:Button text="Disabled" enabled="false" class="ds-btn ds-btn--secondary" style="margin-right: 6px;"/>
                </ui:VisualElement>
                <ui:VisualElement class="ds-row">
                    <ui:Label text="Tertiary" class="ds-body-2" style="width: 70px;"/>
                    <ui:Button text="Default" class="ds-btn ds-btn--tertiary" style="margin-right: 6px;"/>
                    <ui:Button text="Hover" class="ds-btn ds-btn--tertiary" style="margin-right: 6px; background-color: rgb(147, 51, 234);"/>
                    <ui:Button text="Pressed" class="ds-btn ds-btn--tertiary ds-btn--pressed" style="margin-right: 6px;"/>
                    <ui:Button text="Disabled" enabled="false" class="ds-btn ds-btn--tertiary" style="margin-right: 6px;"/>
                </ui:VisualElement>
                <ui:VisualElement class="ds-row">
                    <ui:Label text="Ghost" class="ds-body-2" style="width: 70px;"/>
                    <ui:Button text="Default" class="ds-btn ds-btn--ghost" style="margin-right: 6px;"/>
                    <ui:Button text="Hover" class="ds-btn ds-btn--ghost" style="margin-right: 6px; background-color: rgb(26, 35, 48);"/>
                    <ui:Button text="Pressed" class="ds-btn ds-btn--ghost ds-btn--pressed" style="margin-right: 6px;"/>
                    <ui:Button text="Disabled" enabled="false" class="ds-btn ds-btn--ghost" style="margin-right: 6px;"/>
                </ui:VisualElement>
                <ui:VisualElement class="ds-row">
                    <ui:Label text="Danger" class="ds-body-2" style="width: 70px;"/>
                    <ui:Button text="Default" class="ds-btn ds-btn--danger" style="margin-right: 6px;"/>
                    <ui:Button text="Hover" class="ds-btn ds-btn--danger" style="margin-right: 6px; background-color: rgb(220, 38, 38);"/>
                    <ui:Button text="Pressed" class="ds-btn ds-btn--danger ds-btn--pressed" style="margin-right: 6px;"/>
                    <ui:Button text="Disabled" enabled="false" class="ds-btn ds-btn--danger" style="margin-right: 6px;"/>
                </ui:VisualElement>
                <ui:VisualElement class="ds-row" style="margin-top: 8px;">
                    <ui:Label text="Icon" class="ds-body-2" style="width: 70px;"/>
                    <ui:Button class="ds-btn ds-btn--icon" style="margin-right: 6px; border-color: rgb(34, 197, 94);">
                        <ui:VisualElement class="ds-icon ds-icon--plus ds-icon--accent"/>
                    </ui:Button>
                    <ui:Button class="ds-btn ds-btn--icon" style="margin-right: 6px;">
                        <ui:VisualElement class="ds-icon ds-icon--search"/>
                    </ui:Button>
                    <ui:Button class="ds-btn ds-btn--icon" style="margin-right: 6px;">
                        <ui:VisualElement class="ds-icon ds-icon--sort-asc"/>
                    </ui:Button>
                    <ui:Button class="ds-btn ds-btn--icon" style="margin-right: 6px;">
                        <ui:VisualElement class="ds-icon ds-icon--edit"/>
                    </ui:Button>
                    <ui:Button class="ds-btn ds-btn--icon ds-btn--icon-danger" style="margin-right: 6px;">
                        <ui:VisualElement class="ds-icon ds-icon--trash"/>
                    </ui:Button>
                </ui:VisualElement>
                <ui:VisualElement class="ds-row" style="margin-top: 12px;">
                    <ui:Label text="With Icon" class="ds-body-2" style="width: 70px;"/>
                    <ui:Button class="ds-btn ds-btn--primary ds-btn--with-icon" style="margin-right: 6px;">
                        <ui:VisualElement class="ds-icon ds-icon--check ds-btn__icon"/>
                        <ui:Label text="Save"/>
                    </ui:Button>
                    <ui:Button class="ds-btn ds-btn--secondary ds-btn--with-icon" style="margin-right: 6px;">
                        <ui:VisualElement class="ds-icon ds-icon--share ds-btn__icon"/>
                        <ui:Label text="Share"/>
                    </ui:Button>
                    <ui:Button class="ds-btn ds-btn--tertiary ds-btn--with-icon" style="margin-right: 6px;">
                        <ui:VisualElement class="ds-icon ds-icon--sparkle ds-btn__icon"/>
                        <ui:Label text="Discover"/>
                    </ui:Button>
                </ui:VisualElement>
                <ui:VisualElement class="ds-row">
                    <ui:Label text="" class="ds-body-2" style="width: 70px;"/>
                    <ui:Button class="ds-btn ds-btn--ghost ds-btn--with-icon" style="margin-right: 6px;">
                        <ui:VisualElement class="ds-icon ds-icon--filter ds-btn__icon"/>
                        <ui:Label text="Filter"/>
                    </ui:Button>
                    <ui:Button class="ds-btn ds-btn--danger ds-btn--with-icon" style="margin-right: 6px;">
                        <ui:VisualElement class="ds-icon ds-icon--trash ds-btn__icon"/>
                        <ui:Label text="Delete"/>
                    </ui:Button>
                </ui:VisualElement>
                <ui:VisualElement class="ds-row" style="margin-top: 12px;">
                    <ui:Label text="Disabled" class="ds-body-2" style="width: 70px;"/>
                    <ui:Button enabled="false" class="ds-btn ds-btn--primary ds-btn--with-icon" style="margin-right: 6px;">
                        <ui:VisualElement class="ds-icon ds-icon--check ds-btn__icon"/>
                        <ui:Label text="Save"/>
                    </ui:Button>
                    <ui:Button enabled="false" class="ds-btn ds-btn--ghost ds-btn--with-icon" style="margin-right: 6px;">
                        <ui:VisualElement class="ds-icon ds-icon--filter ds-btn__icon"/>
                        <ui:Label text="Filter"/>
                    </ui:Button>
                    <ui:Button enabled="false" class="ds-btn ds-btn--danger ds-btn--with-icon" style="margin-right: 6px;">
                        <ui:VisualElement class="ds-icon ds-icon--trash ds-btn__icon"/>
                        <ui:Label text="Delete"/>
                    </ui:Button>
                </ui:VisualElement>
                <ui:VisualElement class="ds-row" style="margin-top: 12px;">
                    <ui:Label text="Loading" class="ds-body-2" style="width: 70px;"/>
                    <ui:Button enabled="false" class="ds-btn ds-btn--ghost ds-btn--with-icon" style="margin-right: 6px; min-width: 140px;">
                        <ui:VisualElement class="ds-icon ds-icon--refresh ds-btn__icon is-spinning"/>
                        <ui:Label text="Refreshing..."/>
                    </ui:Button>
                    <ui:Button enabled="false" class="ds-btn ds-btn--primary ds-btn--with-icon" style="margin-right: 6px; min-width: 120px;">
                        <ui:VisualElement class="ds-icon ds-icon--refresh ds-btn__icon is-spinning"/>
                        <ui:Label text="Saving..."/>
                    </ui:Button>
                </ui:VisualElement>
                <ui:VisualElement class="ds-row" style="margin-top: 12px;">
                    <ui:Label text="Back" class="ds-body-2" style="width: 70px;"/>
                    <ui:Button class="ds-btn back-btn" style="align-self: flex-start; margin-top: 0;">
                        <ui:VisualElement class="ds-icon ds-icon--chevron-left back-btn__icon"/>
                        <ui:Label text="Back" class="back-btn__label"/>
                    </ui:Button>
                    <ui:Button enabled="false" class="ds-btn back-btn" style="align-self: flex-start; margin-top: 0; margin-left: 8px;">
                        <ui:VisualElement class="ds-icon ds-icon--chevron-left back-btn__icon"/>
                        <ui:Label text="Back" class="back-btn__label"/>
                    </ui:Button>
                </ui:VisualElement>
            </ui:VisualElement>
            <ui:VisualElement class="ds-section" style="width: 280px;">
                <ui:Label text="INPUTS" class="ds-section__title"/>
                <!-- Inputs render with `value` attribute showing example
                     content rather than absolute-positioned placeholder
                     Labels — Unity Label's intrinsic top margin made the
                     fake placeholders sit a few px below the input's
                     real text baseline. The field's own internal text
                     rendering is correctly centered (input) or top-
                     padded (textarea) by the .ds-input / .ds-textarea
                     rules in Inputs.uss. Real placeholder text in your
                     screens should use Unity 6's
                     `field.textEdition.placeholder = ...` API. -->
                <ui:VisualElement class="ds-search" style="margin-bottom: 8px;">
                    <ui:VisualElement class="ds-icon ds-icon--sm ds-icon--search ds-search__icon"/>
                    <ui:TextField value="Frog" class="ds-search__field"/>
                </ui:VisualElement>
                <ui:TextField value="Sinan Ata" class="ds-input" style="margin-bottom: 8px;"/>
                <ui:DropdownField choices="Common,Rare,Epic,Legendary" index="0" label="" class="ds-dropdown" style="margin-bottom: 8px;"/>
                <ui:Label text="Active input" class="ds-body-2" style="margin-top: 4px; margin-bottom: 4px;"/>
                <ui:TextField value="Typing..." class="ds-input is-active" style="margin-bottom: 8px;"/>
                <ui:VisualElement class="ds-textarea__wrap">
                    <ui:TextField multiline="true" value="Multi-line notes about the selected animal go here. Wraps automatically once the text reaches the right edge of the field." class="ds-textarea"/>
                    <ui:Label text="0/120" class="ds-textarea__counter"/>
                </ui:VisualElement>
            </ui:VisualElement>
            <ui:VisualElement class="ds-section" style="width: 280px;">
                <ui:Label text="TABS &amp; FILTERS" class="ds-section__title"/>
                <ui:VisualElement class="ds-tabs" style="margin-bottom: 12px;">
                    <ui:Button text="All" class="ds-tab is-active"/>
                    <ui:Button text="Common" class="ds-tab"/>
                    <ui:Button text="Rare" class="ds-tab"/>
                    <ui:Button text="Epic" class="ds-tab"/>
                </ui:VisualElement>
                <ui:DropdownField choices="Rarity,Newest,Name (A-Z),Name (Z-A)" index="0" class="ds-dropdown" style="margin-bottom: 12px;"/>
                <ui:VisualElement class="ds-row" style="margin-bottom: 12px;">
                    <ui:Button class="ds-btn ds-btn--icon" style="margin-right: 4px; border-color: rgb(34, 197, 94);">
                        <ui:VisualElement class="ds-icon ds-icon--leaf ds-icon--accent"/>
                    </ui:Button>
                    <ui:Button class="ds-btn ds-btn--icon" style="margin-right: 4px;">
                        <ui:VisualElement class="ds-icon ds-icon--paw"/>
                    </ui:Button>
                    <ui:Button class="ds-btn ds-btn--icon" style="margin-right: 4px;">
                        <ui:VisualElement class="ds-icon ds-icon--droplet"/>
                    </ui:Button>
                    <ui:Button class="ds-btn ds-btn--icon" style="margin-right: 4px;">
                        <ui:VisualElement class="ds-icon ds-icon--mountain"/>
                    </ui:Button>
                    <ui:Button class="ds-btn ds-btn--icon" style="margin-right: 4px;">
                        <ui:VisualElement class="ds-icon ds-icon--tree"/>
                    </ui:Button>
                    <ui:Button class="ds-btn ds-btn--icon" style="margin-right: 4px;">
                        <ui:VisualElement class="ds-icon ds-icon--sparkle"/>
                    </ui:Button>
                </ui:VisualElement>
                <ui:VisualElement class="ds-row" style="margin-bottom: 12px;">
                    <ui:Label text="Sort by:" class="ds-body-2" style="margin-right: 8px;"/>
                    <ui:DropdownField choices="Newest,Oldest" index="0" class="ds-dropdown" style="flex-grow: 1;"/>
                </ui:VisualElement>
                <ui:Label text="VIEW" class="ds-section__title"/>
                <ui:VisualElement class="ds-view-toggle">
                    <ui:Button class="ds-view-toggle__btn is-active">
                        <ui:VisualElement class="ds-icon ds-icon--sm ds-icon--menu"/>
                    </ui:Button>
                    <ui:Button class="ds-view-toggle__btn">
                        <ui:VisualElement class="ds-icon ds-icon--sm ds-icon--list"/>
                    </ui:Button>
                </ui:VisualElement>
            </ui:VisualElement>
            <ui:VisualElement class="ds-section" style="width: 460px;">
                <ui:Label text="ANIMAL CARD (EXAMPLE)" class="ds-section__title"/>
                <ui:VisualElement style="flex-direction: row;">
                    <ui:VisualElement class="ds-animal-card is-selected" style="margin-right: 12px;">
                        <ui:VisualElement class="ds-animal-card__image">
                            <ui:Label text="🐸" style="font-size: 64px;"/>
                        </ui:VisualElement>
                        <ui:VisualElement class="ds-animal-card__rarity">
                            <ui:Label text="COMMON" class="ds-badge ds-badge--common"/>
                        </ui:VisualElement>
                        <ui:VisualElement class="ds-animal-card__title-row">
                            <ui:Label text="Frog" class="ds-animal-card__title"/>
                            <ui:VisualElement class="ds-icon ds-icon--xs ds-icon--sparkle ds-icon--gold"/>
                        </ui:VisualElement>
                        <ui:VisualElement class="ds-animal-card__footer">
                            <ui:Label text="Equipped" class="ds-text-success"/>
                        </ui:VisualElement>
                        <ui:VisualElement class="ds-animal-card__check">
                            <ui:VisualElement class="ds-icon ds-icon--xs ds-icon--check ds-icon--on-accent"/>
                        </ui:VisualElement>
                    </ui:VisualElement>
                    <ui:VisualElement class="ds-animal-card is-epic">
                        <ui:VisualElement class="ds-animal-card__image">
                            <ui:Label text="🐊" style="font-size: 64px;"/>
                        </ui:VisualElement>
                        <ui:VisualElement class="ds-animal-card__rarity">
                            <ui:Label text="EPIC" class="ds-badge ds-badge--epic"/>
                        </ui:VisualElement>
                        <ui:VisualElement class="ds-animal-card__title-row">
                            <ui:Label text="Crocodile" class="ds-animal-card__title"/>
                        </ui:VisualElement>
                        <ui:VisualElement class="ds-animal-card__footer">
                            <ui:Button text="Equip" class="ds-btn ds-btn--primary ds-btn--block"/>
                        </ui:VisualElement>
                    </ui:VisualElement>
                </ui:VisualElement>
            </ui:VisualElement>
            <ui:VisualElement class="ds-section" style="width: 400px;">
                <ui:Label text="ANIMAL DETAIL PAGE (EXAMPLE)" class="ds-section__title"/>
                <ui:VisualElement class="ds-animal-detail">
                    <ui:VisualElement class="ds-animal-detail__hero">
                        <ui:Label text="🐸" style="font-size: 96px;"/>
                        <ui:Button class="ds-btn ds-btn--icon ds-animal-detail__hero-back">
                            <ui:VisualElement class="ds-icon ds-icon--arrow-left"/>
                        </ui:Button>
                        <ui:Button class="ds-btn ds-btn--icon ds-animal-detail__hero-more">
                            <ui:VisualElement class="ds-icon ds-icon--more-horizontal"/>
                        </ui:Button>
                        <ui:VisualElement class="ds-carousel-dots">
                            <ui:VisualElement class="ds-carousel-dot is-active"/>
                            <ui:VisualElement class="ds-carousel-dot"/>
                            <ui:VisualElement class="ds-carousel-dot"/>
                            <ui:VisualElement class="ds-carousel-dot"/>
                            <ui:VisualElement class="ds-carousel-dot"/>
                        </ui:VisualElement>
                    </ui:VisualElement>
                    <ui:VisualElement class="ds-animal-detail__body">
                        <ui:VisualElement class="ds-animal-detail__header-row">
                            <ui:Label text="COMMON" class="ds-badge ds-badge--common"/>
                            <ui:VisualElement class="ds-chip ds-chip--equipped">
                                <ui:VisualElement class="ds-icon ds-icon--xs ds-icon--check ds-chip__icon"/>
                                <ui:Label text="Equipped"/>
                            </ui:VisualElement>
                        </ui:VisualElement>
                        <ui:VisualElement class="ds-animal-detail__title-block" style="margin-top: 4px;">
                            <ui:Label text="Frog" class="ds-h2" style="margin-right: 6px;"/>
                            <ui:VisualElement class="ds-icon ds-icon--sm ds-icon--sparkle ds-icon--gold"/>
                        </ui:VisualElement>
                        <ui:VisualElement style="margin-top: 8px;">
                            <ui:Label text="Amphibious" class="ds-tag ds-tag--amphibious" style="align-self: flex-start;"/>
                        </ui:VisualElement>
                        <ui:Label text="A small amphibious creature that lives near ponds and jumps around happily." class="ds-animal-detail__description"/>
                        <ui:VisualElement class="ds-info-row">
                            <ui:VisualElement class="ds-info-row__left">
                                <ui:VisualElement class="ds-icon ds-icon--sm ds-icon--paw ds-info-row__icon"/>
                                <ui:Label text="Rarity" class="ds-info-row__label"/>
                            </ui:VisualElement>
                            <ui:Label text="Common" class="ds-info-row__value"/>
                        </ui:VisualElement>
                        <ui:VisualElement class="ds-info-row">
                            <ui:VisualElement class="ds-info-row__left">
                                <ui:VisualElement class="ds-icon ds-icon--sm ds-icon--leaf ds-info-row__icon"/>
                                <ui:Label text="Habitat" class="ds-info-row__label"/>
                            </ui:VisualElement>
                            <ui:Label text="Pond" class="ds-info-row__value"/>
                        </ui:VisualElement>
                        <ui:VisualElement class="ds-info-row">
                            <ui:VisualElement class="ds-info-row__left">
                                <ui:VisualElement class="ds-icon ds-icon--sm ds-icon--heart ds-icon--danger ds-info-row__icon"/>
                                <ui:Label text="Energy" class="ds-info-row__label"/>
                            </ui:VisualElement>
                            <ui:Label text="10" class="ds-info-row__value"/>
                        </ui:VisualElement>
                        <ui:VisualElement class="ds-info-row">
                            <ui:VisualElement class="ds-info-row__left">
                                <ui:VisualElement class="ds-icon ds-icon--sm ds-icon--sparkle ds-icon--gold ds-info-row__icon"/>
                                <ui:Label text="Discovered" class="ds-info-row__label"/>
                            </ui:VisualElement>
                            <ui:Label text="May 12, 2024" class="ds-info-row__value"/>
                        </ui:VisualElement>
                        <ui:VisualElement class="ds-animal-detail__actions">
                            <ui:Button text="Unequip" class="ds-btn ds-btn--ghost"/>
                            <ui:Button text="View Skins" class="ds-btn ds-btn--primary"/>
                        </ui:VisualElement>
                    </ui:VisualElement>
                </ui:VisualElement>
            </ui:VisualElement>
            <ui:VisualElement class="ds-section" style="width: 460px;">
                <ui:Label text="NAVIGATION" class="ds-section__title"/>
                <ui:VisualElement style="flex-direction: row;">
                    <ui:VisualElement class="ds-side-nav" style="margin-right: 12px;">
                        <ui:Button class="ds-nav-item is-active">
